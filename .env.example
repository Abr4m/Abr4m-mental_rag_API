# ── Copy to .env and fill in values ──────────────────────────────────────────
# Dataset
CSV_PATH=data/mental_with_multilabels.csv

# Model names (change to use different HuggingFace checkpoints)
BI_ENCODER_MODEL=all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
LLM_MAX_NEW_TOKENS=200

# Use-case defaults
DEFAULT_N_TIPS=5
DEFAULT_TAG_FILTER=All

# Set to True to skip Qwen and use the fast fallback (useful for cold-start testing)
USE_FALLBACK_LLM=False

# Server
HOST=0.0.0.0
PORT=7860
WORKERS=1
